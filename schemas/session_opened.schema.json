    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    }
  },
  "required": [
    "session_id"
  ],
  "title": "SessionOpened",
  "type": "object"
}
