{
  "$defs": {
    "ChannelValue": {
      "description": "A channel sample: a flat list of floats plus an optional unit string. Width\ncarries the semantics (1=scalar, 3=vec3, 4=quat, N=array).",
      "properties": {
        "data": {
          "default": [],
          "items": {
            "format": "double",
            "type": "number"
          },
          "type": "array"
        },
        "unit": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Plant → controller: the latest sensed state. Carries `seq`/`t` so a command\ncan be stamped with the sensor it was computed from (the correspondence the\nsplit perception/action planes must preserve — join on `seq`, not arrival).",
  "properties": {
    "channels": {
      "additionalProperties": {
        "$ref": "#/$defs/ChannelValue"
      },
      "default": {},
      "type": "object"
    },
    "frame_id": {
      "default": "world",
      "type": "string"
    },
    "kind": {
      "const": "sensor_frame",
      "default": "sensor_frame",
      "type": "string"
    },
    "ncp_version": {
      "default": "0.4",
      "type": "string"
    },
    "seq": {
      "default": 0,
      "format": "int64",
      "type": "integer"
    },
    "t": {
      "default": 0.0,
      "format": "double",
      "type": "number"
    }
  },
  "required": [],
  "title": "SensorFrame",
  "type": "object"
}
