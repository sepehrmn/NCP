{
  "$defs": {
    "ChannelValue": {
      "description": "A channel sample: a flat list of floats plus an optional unit string.\n\nWidth carries the semantics (1=scalar, 3=vec3, 4=quat, N=array), so the\nenvelope stays generic and any project can add channels without schema\nchanges.",
      "properties": {
        "data": {
          "items": {
            "type": "number"
          },
          "title": "Data",
          "type": "array"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "title": "ChannelValue",
      "type": "object"
    }
  },
  "description": "Plant -> controller: the latest sensed state.",
  "properties": {
    "ncp_version": {
      "default": "0.4",
      "title": "Ncp Version",
      "type": "string"
    },
    "kind": {
      "const": "sensor_frame",
      "default": "sensor_frame",
      "title": "Kind",
      "type": "string"
    },
    "seq": {
      "default": 0,
      "title": "Seq",
      "type": "integer"
    },
    "t": {
      "default": 0.0,
      "title": "T",
      "type": "number"
    },
    "frame_id": {
      "default": "world",
      "title": "Frame Id",
      "type": "string"
    },
    "channels": {
      "additionalProperties": {
        "$ref": "#/$defs/ChannelValue"
      },
      "title": "Channels",
      "type": "object"
    }
  },
  "title": "SensorFrame",
  "type": "object"
}
