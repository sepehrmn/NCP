{
  "$defs": {
    "ChannelValue": {
      "description": "A channel sample: a flat list of floats plus an optional unit string.\n\nWidth carries the semantics (1=scalar, 3=vec3, 4=quat, N=array), so the\nenvelope stays generic and any project can add channels without schema\nchanges.",
      "properties": {
        "data": {
          "items": {
            "type": "number"
          },
          "title": "Data",
          "type": "array"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "title": "ChannelValue",
      "type": "object"
    }
  },
  "properties": {
    "ncp_version": {
      "default": "0.1",
      "title": "Ncp Version",
      "type": "string"
    },
    "kind": {
      "const": "stimulus_frame",
      "default": "stimulus_frame",
      "title": "Kind",
      "type": "string"
    },
    "session_id": {
      "title": "Session Id",
      "type": "string"
    },
    "t": {
      "default": 0.0,
      "title": "T",
      "type": "number"
    },
    "values": {
      "additionalProperties": {
        "$ref": "#/$defs/ChannelValue"
      },
      "title": "Values",
      "type": "object"
    }
  },
  "required": [
    "session_id"
  ],
  "title": "StimulusFrame",
  "type": "object"
}
